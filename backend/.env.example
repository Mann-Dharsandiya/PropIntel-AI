 # Server
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# MongoDB
MONGO_URI=mongodb://localhost:27017/propintel_ai

# JWT (legacy / generic — kept for backward compatibility)
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# JWT — Auth Module (access + refresh token pair)
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# bcrypt
BCRYPT_SALT_ROUNDS=12

# CORS
CLIENT_ORIGIN=http://localhost:5173

# ML Service
ML_SERVICE_URL=http://localhost:8000