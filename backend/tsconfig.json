 {
  "compilerOptions": {
    "target": "ES2022",

    "module": "Node16",
    "moduleResolution": "Node16",

    "lib": ["ES2022"],

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "baseUrl": "./src",

    "paths": {
      "@/*": ["*"]
    },

    "types": [
      "node",
      "express"
    ],

    "sourceMap": true,
    "declaration": false,

    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },

  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}