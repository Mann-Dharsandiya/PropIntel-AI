 {
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "moduleResolution": "node",

    "declaration": false,
    "sourceMap": true,

    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    },

    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ],

    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": true,

    "ignoreDeprecations": "6.0"
  },

  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}