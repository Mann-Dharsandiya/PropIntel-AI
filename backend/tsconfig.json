 {
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "baseUrl": "./src",

    "paths": {
      "@/*": ["*"]
    },

    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ],

    "types": [
      "node",
      "express"
    ],

    "sourceMap": true,

    "declaration": false,

    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },

  "include": [
    "src/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}