# ---------------------------------------------------------------------------
# Root convenience file. Each service also has its own .env.example
# (frontend/.env.example, backend/.env.example, ml-service/.env.example).
# Copy this to .env only if you're using docker-compose from the project root.
# ---------------------------------------------------------------------------

# Backend
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
MONGO_URI=mongodb://mongo:27017/propintel_ai
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173
ML_SERVICE_URL=http://ml-service:8000

# Frontend
VITE_API_BASE_URL=http://localhost:5000/api/v1
VITE_APP_NAME=PropIntel AI

# ML Service
ENVIRONMENT=development
HOST=0.0.0.0
PORT_ML=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:5000

# MongoDB (docker-compose)
MONGO_INITDB_ROOT_USERNAME=propintel
MONGO_INITDB_ROOT_PASSWORD=propintel_dev_password
